# カード作成時に Google スプレッドシートへ追記する場合に設定
# GAS を「ウェブアプリ」としてデプロイした URL を貼り付ける
# 空のまままたは未設定の場合はスプレッドシート連携は行いません
VITE_SHEET_SYNC_URL=

# 左サイドバー「カレンダー」から Googleカレンダーにイベントを作成する場合に設定
# Google Cloud コンソールで OAuth 2.0 クライアント ID（ウェブアプリ）を作成し、Google Calendar API を有効にしてください
# 未設定の場合はモーダルでエラーメッセージが表示されます
VITE_GOOGLE_CLIENT_ID=
