# カード作成時に Google スプレッドシートへ追記する場合に設定
# GAS を「ウェブアプリ」としてデプロイした URL を貼り付ける
# 空のまままたは未設定の場合はスプレッドシート連携は行いません
VITE_SHEET_SYNC_URL=

# 左サイドバー「カレンダー」から Googleカレンダーにイベントを作成する場合に設定
# Google Cloud コンソールで OAuth 2.0 クライアント ID（ウェブアプリ）を作成し、Google Calendar API を有効にしてください
# 未設定の場合はモーダルでエラーメッセージが表示されます
VITE_GOOGLE_CLIENT_ID=

# 不具合通知（カード→目安箱DnD）の送信先 email。未設定なら izumi.coinzoom@gmail.com
VITE_INCIDENT_REPORT_TO=

# 秘書Bot Worker URL ＋ 不具合通知エンドポイント用シークレット
# 設定すると Firestore 通知と並行して Discord 整形通知が秘書Bot経由で飛ぶ（Phase B）
# 未設定なら Discord 通知はスキップ（Firestore 通知のみ）
VITE_SECRETARY_BOT_URL=
VITE_SECRETARY_BOT_INCIDENT_SECRET=
