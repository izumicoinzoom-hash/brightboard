{
  "name": "kiyota-kotei-kanri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "guard": "node scripts/check-forbidden-patterns.mjs",
    "backup": "node scripts/backup-tasks.mjs",
    "backup-loaner": "node scripts/backup-loaner-snapshot.mjs",
    "restore": "node scripts/restore-tasks.mjs",
    "build": "node scripts/check-forbidden-patterns.mjs && vite build",
    "build:demo": "node scripts/check-forbidden-patterns.mjs && vite build --mode demo && node -e \"require('fs').copyFileSync('public/.htaccess.demo','dist/.htaccess')\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "firebase": "^12.10.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "firebase-admin": "^13.8.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.10",
    "vitest": "^2.1.0"
  }
}
