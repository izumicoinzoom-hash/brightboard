rules_version = '2';

// BrightBoard 鈑金版 写真撮影機能 (Phase 1) — Firebase Storage セキュリティルール
//
// パス構造: /photos/{taskId}/{folderName}/{filename}
// 例: /photos/abc123/個人 中島_トヨタ プリウス_5012/IN_20260430_001.jpg
//
// 設計:
//   - 認証済みユーザーのみ読み書き可能
//   - 画像 (image/*) / 動画 (video/*) のみ受け付け
//   - 1ファイル最大 50MB（720p 30秒動画 + 静止画上限）
//   - 既存の invoice-pdfs ルールは継続維持

service firebase.storage {
  match /b/{bucket}/o {

    // BB鈑金版 撮影機能 - 写真/動画
    match /photos/{taskId}/{folderName}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
        );
      allow delete: if request.auth != null;
    }

    // それ以外は全禁止（既存ルールと整合）
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
