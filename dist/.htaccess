# SPA: 存在しないパスは index.html に振り向ける（Xserver など Apache 用）
# サブフォルダ（例: /kotei/）に配置する場合は RewriteBase と最後の RewriteRule を変更すること
RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# キャッシュ制御:
# - index.html は毎回最新を取得させる（バンドルのハッシュ参照を最新に保つため）
# - ハッシュ付きアセット（vite が出力する index-XXXX.js / .css 等）は1年キャッシュOK
<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "^version\.json$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(js|css|woff2?|ttf|png|jpe?g|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
