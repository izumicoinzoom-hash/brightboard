# デモ用ビルドの設定例（コピーして .env.demo として保存し、値を埋めてください）
# 本番用 .env とは別に、デモ専用 Firebase プロジェクトの利用を推奨します。

# デモ用の公開パス（サーバーに /kiyota/demo/ で配置する場合）
VITE_BASE_PATH=/kiyota/demo/
# デモ環境であることを画面上に表示する
VITE_DEMO_MODE=true

# デモ用 Firebase プロジェクト（本番とは別プロジェクトを推奨）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ログイン許可メール（空の場合は全Googleアカウント可。デモ用に空でも可）
VITE_ALLOWED_EMAILS=
VITE_SHEET_SYNC_URL=
VITE_GOOGLE_CLIENT_ID=
